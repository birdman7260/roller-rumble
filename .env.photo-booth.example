# Optional photo-booth-only overrides.
# Copy to .env.photo-booth or .env.photo-booth.local on the Raspberry Pi.

GOLDSPRINTS_BOOTH_SERVER_URL=http://127.0.0.1:3187
GOLDSPRINTS_BOOTH_ID=booth-dev
GOLDSPRINTS_BOOTH_SECRET=dev-secret
GOLDSPRINTS_BOOTH_PORT=3197
GOLDSPRINTS_BOOTH_DATA_DIR=.goldsprints-booth
GOLDSPRINTS_BOOTH_CAMERA=simulator
GOLDSPRINTS_BOOTH_SIMULATOR_PHOTO_PATH=tools/photo-booth-agent/assets/simulated-dslr-photo.jpg
GOLDSPRINTS_BOOTH_SCANNER_MODE=simulator
GOLDSPRINTS_WLED_DEFAULT_LOOK=solid-white
GOLDSPRINTS_UMBRELLA_MODE=simulator

# Local manual testing only. When enabled, type fake:Your Name into the kiosk manual QR input.
GOLDSPRINTS_BOOTH_ALLOW_FAKE_QR=1

# Hardware mode:
# GOLDSPRINTS_BOOTH_SERVER_URL=http://<admin-laptop-ip>:3187
# GOLDSPRINTS_BOOTH_CAMERA=gphoto2
# GOLDSPRINTS_GPHOTO_PATH=gphoto2
# GOLDSPRINTS_BOOTH_SCANNER_MODE=serial
# GOLDSPRINTS_BOOTH_SCANNER_SERIAL_PORT=/dev/serial0
# GOLDSPRINTS_BOOTH_SCANNER_BAUD=9600
# GOLDSPRINTS_WLED_SERIAL_PORT=/dev/ttyUSB0
# GOLDSPRINTS_WLED_BAUD=115200
# GOLDSPRINTS_WLED_IDLE_PRESET=1
# GOLDSPRINTS_BOOTH_DATA_DIR=/home/pi/goldsprints-booth
# GOLDSPRINTS_UMBRELLA_MODE=process
# GOLDSPRINTS_BOOTH_PYTHON=python3
# GOLDSPRINTS_UMBRELLA_STEP_PIN=17
# GOLDSPRINTS_UMBRELLA_DIR_PIN=27
# GOLDSPRINTS_UMBRELLA_ENABLE_PIN=22
# GOLDSPRINTS_UMBRELLA_HALL_PIN=23
# GOLDSPRINTS_UMBRELLA_PANEL_COUNT=8
# GOLDSPRINTS_UMBRELLA_STEPS_PER_REVOLUTION=200
# GOLDSPRINTS_UMBRELLA_MICROSTEPS=16
# GOLDSPRINTS_UMBRELLA_HOME_DIRECTION=-1
# GOLDSPRINTS_UMBRELLA_SPIN_RPM=3
# GOLDSPRINTS_UMBRELLA_MOVE_RPM=8
# GOLDSPRINTS_UMBRELLA_HOMING_TIMEOUT_MS=15000
