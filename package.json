{
  "name": "goldsprints",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for the GoldSprints race app and hardware-adjacent tooling.",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @goldsprints/desktop dev",
    "dev:debug": "pnpm --filter @goldsprints/desktop dev:debug",
    "dev:debug:break": "pnpm --filter @goldsprints/desktop dev:debug:break",
    "build": "pnpm --filter @goldsprints/desktop build",
    "cloudflared:doctor": "pnpm --filter @goldsprints/desktop cloudflared:doctor",
    "cloudflared:install": "pnpm --filter @goldsprints/desktop cloudflared:install",
    "cloudflared:version": "pnpm --filter @goldsprints/desktop cloudflared:version",
    "db:studio": "node scripts/run-db-studio.mjs",
    "dev:reset-data": "node scripts/reset-dev-data.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "notifications:keys": "pnpm --filter @goldsprints/desktop notifications:keys",
    "os2l:cue": "node scripts/send-os2l-cue.mjs",
    "photo-booth:agent": "node scripts/run-photo-booth-agent.mjs",
    "photo-booth:doctor": "node scripts/run-photo-booth-check.mjs doctor",
    "photo-booth:test": "node scripts/run-photo-booth-check.mjs test",
    "photo-booth:typecheck": "node scripts/run-photo-booth-check.mjs typecheck",
    "package:app": "pnpm --filter @goldsprints/desktop package:app",
    "package:dir": "pnpm --filter @goldsprints/desktop package:dir",
    "package:mac": "pnpm --filter @goldsprints/desktop package:mac",
    "package:win": "pnpm --filter @goldsprints/desktop package:win",
    "preview": "pnpm --filter @goldsprints/desktop preview",
    "quality": "prettier --check . && eslint .",
    "rebuild:native": "pnpm --filter @goldsprints/desktop rebuild:native",
    "start": "pnpm --filter @goldsprints/desktop start",
    "test": "pnpm --filter @goldsprints/shared test && pnpm --filter @goldsprints/desktop test && node scripts/run-photo-booth-check.mjs test",
    "test:watch": "pnpm --filter @goldsprints/desktop test:watch",
    "typecheck": "pnpm --filter @goldsprints/shared typecheck && pnpm --filter @goldsprints/shared-ui typecheck && pnpm --filter @goldsprints/desktop typecheck && node scripts/run-photo-booth-check.mjs typecheck"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tanstack/eslint-plugin-query": "^5.100.6",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1"
  }
}
