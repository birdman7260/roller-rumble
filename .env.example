# GoldSprints local app configuration.
# Copy to .env or .env.local and adjust for your machine.

# Dev scripts already default to .goldsprints-dev/runtime, but setting this here keeps every local
# script pointed at the same disposable database/uploads folder.
GOLDSPRINTS_DATA_DIR=.goldsprints-dev/runtime
GOLDSPRINTS_PORT=3187
GOLDSPRINTS_OS2L_PORT=9996
GOLDSPRINTS_DEBUG=0
GOLDSPRINTS_OPEN_DEVTOOLS=0
# Optional override for the LAN address shown in QR codes and photo booth pairing. Leave unset to
# auto-detect Wi-Fi/Ethernet. Set this if macOS picks a VPN or virtual adapter instead.
# GOLDSPRINTS_LOCAL_SERVER_HOST=192.168.1.42

# Public racer-page tunnel. Quick mode creates a temporary trycloudflare.com URL. Token mode uses
# a stable Cloudflare Tunnel such as https://goldsprints.birdsnest.family/racer.
GOLDSPRINTS_TUNNEL_MODE=quick
# GOLDSPRINTS_TUNNEL_MODE=token
# GOLDSPRINTS_TUNNEL_NAME=GoldSprints
# GOLDSPRINTS_PUBLIC_RACER_URL=https://goldsprints.birdsnest.family/racer
# GOLDSPRINTS_TUNNEL_TOKEN=keep-this-in-env-local-only
# GOLDSPRINTS_CLOUDFLARED_PATH=/absolute/path/to/cloudflared
# Optional comma-separated extra hostnames that Vite dev mode should allow through the tunnel.
# GOLDSPRINTS_VITE_ALLOWED_HOSTS=another-event-domain.example

# Stripe Checkout for event entrance fees. Keep live keys in .env.local only. The public racer URL
# may be the site root or /racer; the app normalizes it before building Checkout return URLs.
# GOLDSPRINTS_STRIPE_SECRET_KEY=sk_test_...
# GOLDSPRINTS_STRIPE_WEBHOOK_SECRET=whsec_...

# Browser Web Push for racer notifications. Generate these with `pnpm notifications:keys` and keep
# the private key in .env.local only.
# GOLDSPRINTS_WEB_PUSH_PUBLIC_KEY=...
# GOLDSPRINTS_WEB_PUSH_PRIVATE_KEY=...
# GOLDSPRINTS_WEB_PUSH_SUBJECT=mailto:you@example.com

# Only VITE_* variables are exposed to the browser renderer by Vite. VITE_API_BASE is only honored
# when the page itself is loaded from localhost/127.0.0.1 so public tunnel visitors do not try to
# connect to their own device.
VITE_API_BASE=http://127.0.0.1:3187

# These booth defaults are enough for simulator-mode local testing.
GOLDSPRINTS_BOOTH_SERVER_URL=http://127.0.0.1:3187
GOLDSPRINTS_BOOTH_ID=booth-dev
GOLDSPRINTS_BOOTH_SECRET=dev-secret
GOLDSPRINTS_BOOTH_PORT=3197
GOLDSPRINTS_BOOTH_DATA_DIR=.goldsprints-booth
GOLDSPRINTS_BOOTH_CAMERA=simulator
GOLDSPRINTS_BOOTH_SIMULATOR_PHOTO_PATH=tools/photo-booth-agent/assets/simulated-dslr-photo.jpg
GOLDSPRINTS_BOOTH_SCANNER_MODE=simulator
GOLDSPRINTS_WLED_DEFAULT_LOOK=solid-white
GOLDSPRINTS_UMBRELLA_MODE=simulator
GOLDSPRINTS_BOOTH_ALLOW_FAKE_QR=1

# Raspberry Pi hardware example:
# GOLDSPRINTS_BOOTH_CAMERA=gphoto2
# GOLDSPRINTS_BOOTH_SCANNER_MODE=serial
# GOLDSPRINTS_BOOTH_SCANNER_SERIAL_PORT=/dev/serial0
# GOLDSPRINTS_WLED_SERIAL_PORT=/dev/ttyUSB0
# GOLDSPRINTS_UMBRELLA_MODE=process
