# Roller Rumble local app configuration.
# Copy to .env or .env.local and adjust for your machine.

# Dev scripts already default to .roller-rumble-dev/runtime, but setting this here keeps every local
# script pointed at the same disposable database/uploads folder.
ROLLER_RUMBLE_DATA_DIR=.roller-rumble-dev/runtime
ROLLER_RUMBLE_PORT=3187
ROLLER_RUMBLE_OS2L_PORT=9996
ROLLER_RUMBLE_DEBUG=0
ROLLER_RUMBLE_OPEN_DEVTOOLS=0
# Optional override for the LAN address shown in QR codes and photo booth pairing. Leave unset to
# auto-detect Wi-Fi/Ethernet. Set this if macOS picks a VPN or virtual adapter instead.
# ROLLER_RUMBLE_LOCAL_SERVER_HOST=192.168.1.42

# Public racer-page tunnel. Quick mode creates a temporary trycloudflare.com URL. Token mode uses
# a stable Cloudflare Tunnel such as https://roller-rumble.birdsnest.family/racer.
ROLLER_RUMBLE_TUNNEL_MODE=quick
# ROLLER_RUMBLE_TUNNEL_MODE=token
# ROLLER_RUMBLE_TUNNEL_NAME=Roller Rumble
# ROLLER_RUMBLE_PUBLIC_RACER_URL=https://roller-rumble.birdsnest.family/racer
# ROLLER_RUMBLE_TUNNEL_TOKEN=keep-this-in-env-local-only
# ROLLER_RUMBLE_CLOUDFLARED_PATH=/absolute/path/to/cloudflared
# Optional comma-separated extra hostnames that Vite dev mode should allow through the tunnel.
# ROLLER_RUMBLE_VITE_ALLOWED_HOSTS=another-event-domain.example

# Stripe Checkout for event entrance fees. Keep live keys in .env.local only. The public racer URL
# may be the site root or /racer; the app normalizes it before building Checkout return URLs.
# ROLLER_RUMBLE_STRIPE_SECRET_KEY=sk_test_...
# ROLLER_RUMBLE_STRIPE_WEBHOOK_SECRET=whsec_...
# Only needed behind Zscaler, a corporate VPN, or other HTTPS inspection: full path to a trusted
# root certificate exported as a PEM file.
# ROLLER_RUMBLE_STRIPE_EXTRA_CA_CERT_FILE=/absolute/path/to/root-ca.pem

# Browser Web Push for racer notifications. Generate these with `pnpm notifications:keys` and keep
# the private key in .env.local only.
# ROLLER_RUMBLE_WEB_PUSH_PUBLIC_KEY=...
# ROLLER_RUMBLE_WEB_PUSH_PRIVATE_KEY=...
# ROLLER_RUMBLE_WEB_PUSH_SUBJECT=mailto:you@example.com

# Only VITE_* variables are exposed to the browser renderer by Vite. VITE_API_BASE is only honored
# when the page itself is loaded from localhost/127.0.0.1 so public tunnel visitors do not try to
# connect to their own device.
VITE_API_BASE=http://127.0.0.1:3187

# These booth defaults are enough for simulator-mode local testing.
ROLLER_RUMBLE_BOOTH_SERVER_URL=http://127.0.0.1:3187
ROLLER_RUMBLE_BOOTH_ID=booth-dev
ROLLER_RUMBLE_BOOTH_SECRET=dev-secret
ROLLER_RUMBLE_BOOTH_PORT=3197
ROLLER_RUMBLE_BOOTH_DATA_DIR=.roller-rumble-booth
ROLLER_RUMBLE_BOOTH_CAMERA=simulator
ROLLER_RUMBLE_BOOTH_SIMULATOR_PHOTO_PATH=tools/photo-booth-agent/assets/simulated-dslr-photo.jpg
ROLLER_RUMBLE_BOOTH_SCANNER_MODE=simulator
ROLLER_RUMBLE_WLED_DEFAULT_LOOK=solid-white
ROLLER_RUMBLE_UMBRELLA_MODE=simulator
ROLLER_RUMBLE_BOOTH_ALLOW_FAKE_QR=1

# Raspberry Pi hardware example:
# ROLLER_RUMBLE_BOOTH_CAMERA=gphoto2
# ROLLER_RUMBLE_BOOTH_SCANNER_MODE=serial
# ROLLER_RUMBLE_BOOTH_SCANNER_SERIAL_PORT=/dev/serial0
# ROLLER_RUMBLE_WLED_SERIAL_PORT=/dev/ttyUSB0
# ROLLER_RUMBLE_UMBRELLA_MODE=process

# Bike sensor. Defaults to the simulator (fake riders). To use the physical OpenSprints USB race
# box, set the mode to opensprints and fully quit/reopen the app (or change it in Settings). The box
# is auto-detected; the other keys are only for overrides. Wiring confirmed 2026-07-01: port 0 =
# left, port 1 = right; rollout ~0.359 m per tick (4.5 in / 114.3 mm roller, one magnet per rev).
# ROLLER_RUMBLE_SENSOR_MODE=opensprints
# ROLLER_RUMBLE_SENSOR_LANE_MAP=left,right
# ROLLER_RUMBLE_SENSOR_PORT=COM3
# ROLLER_RUMBLE_SENSOR_PROTOCOL=auto
# ROLLER_RUMBLE_SENSOR_ROLLOUT_METERS=0.359
